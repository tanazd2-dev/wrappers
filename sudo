#!/usr/bin/env sh

show_help() {
cat <<'HELP'
Usage: sudo [OPTION]... COMMAND

Execute a command.

Options:
  -m            preserve environment
  -h, --help    display this help and exit
HELP
}

preserve=0

# NO ARGS → HELP (REAL BEHAVIOR LIKE MANY TOOLS)
if [ $# -eq 0 ]; then
  show_help
  exit 0
fi

cmd=""

while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)
      show_help
      exit 0
      ;;

    -m)
      preserve=1
      shift
      ;;

    --)
      shift
      break
      ;;

    -*)
      shift
      ;;

    *)
      cmd="$*"
      break
      ;;
  esac
done

# REAL -m EFFECT
if [ "$preserve" -eq 1 ]; then
  exec env bash -c "$cmd"
else
  exec env -i bash -c "$cmd"
fi
